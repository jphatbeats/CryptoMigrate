modules = ["python-3.11", "nodejs-20", "python3"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Crypto Trading Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "crypto_trading_server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord AI Alerts"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Hourly Trade Scanner"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Enhanced Discord Intelligence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord GPT Commands"

[[workflows.workflow]]
name = "Crypto Trading Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install flask ccxt && python main_server.py"
waitForPort = 5000

[[workflows.workflow]]
name = "crypto_trading_server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install flask ccxt python-dotenv"

[[workflows.workflow]]
name = "Discord AI Alerts"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python automated_trading_alerts.py"

[[workflows.workflow]]
name = "Hourly Trade Scanner"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python start_live_scanner.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Enhanced Discord Intelligence"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python enhanced_discord_trading_intelligence.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Discord GPT Commands"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python start_discord_gpt_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80
